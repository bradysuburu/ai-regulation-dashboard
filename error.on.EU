<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>AI Regulation Dashboard</title>
<style>
:root {
  --bg:#f5f6fb;
  --panel:#ffffff;
  --text:#172033;
  --muted:#667085;
  --border:#e4e7ec;
  --green:#276749;
  --purple:#534AB7;
  --shadow:0 18px 45px rgba(16,24,40,.08);
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color:var(--text);
  background:
    radial-gradient(circle at 8% 8%, rgba(39,103,73,.10), transparent 28%),
    radial-gradient(circle at 92% 4%, rgba(83,74,183,.12), transparent 30%),
    var(--bg);
  min-height:100vh;
}
.shell{max-width:1180px;margin:0 auto;padding:28px 24px 36px;}
.header{
  background:linear-gradient(135deg,#fff 0%,#fbfcff 100%);
  border:1px solid var(--border);
  box-shadow:var(--shadow);
  border-radius:30px;
  padding:28px;
  margin-bottom:18px;
}
.eyebrow{font-size:12px;letter-spacing:.11em;text-transform:uppercase;font-weight:800;color:var(--green);margin-bottom:8px;}
h1{font-size:38px;line-height:1.05;letter-spacing:-.035em;margin-bottom:10px;}
.header p{font-size:15px;line-height:1.65;color:var(--muted);max-width:820px;}
.nav{
  position:sticky;top:0;z-index:10;
  display:flex;gap:10px;flex-wrap:wrap;
  padding:12px;
  margin-bottom:18px;
  background:rgba(255,255,255,.78);
  backdrop-filter:blur(16px);
  border:1px solid var(--border);
  border-radius:22px;
  box-shadow:0 10px 28px rgba(16,24,40,.05);
}
.nav button{
  appearance:none;border:1px solid var(--border);background:#fff;color:#475467;
  border-radius:999px;padding:10px 15px;font-size:13px;font-weight:750;cursor:pointer;
  transition:transform .12s, box-shadow .15s, border-color .15s, color .15s;
}
.nav button:hover{transform:translateY(-1px);box-shadow:0 8px 20px rgba(16,24,40,.08);}
.nav button.active{border-color:var(--green);color:var(--green);box-shadow:0 8px 20px rgba(39,103,73,.12);}
.section-title{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin:4px 2px 12px;}
.section-title h2{font-size:20px;letter-spacing:-.02em;}
.section-title span{font-size:12px;color:var(--muted);}
.frame-card{
  background:#fff;border:1px solid var(--border);border-radius:26px;box-shadow:var(--shadow);
  overflow:hidden;
}
iframe{width:100%;border:0;display:block;background:#fff;}
.panel{display:none;}
.panel.active{display:block;}
.footer-note{margin-top:14px;font-size:12px;color:var(--muted);text-align:center;}
@media (max-width:720px){
  .shell{padding:16px 12px 28px;}
  .header{padding:22px;border-radius:24px;}
  h1{font-size:30px;}
  .section-title{display:block;}
  .section-title span{display:block;margin-top:4px;}
}
</style>
</head>
<body>
<div class="shell">
  <header class="header">
    <div class="eyebrow">Interactive AI Regulation Dashboard</div>
    <h1>AI Regulation: Global Strategy + EU Compliance</h1>
    <p>Use this dashboard to compare global AI regulatory approaches, then drill into the EU AI Act obligations that matter most for SMEs and companies building AI-enabled products.</p>
  </header>

  <nav class="nav" aria-label="Dashboard navigation">
    <button class="active" onclick="Dashboard.showPanel('global', this)">🌍 Global Comparison</button>
    <button onclick="Dashboard.showPanel('eu', this)">🇪🇺 EU AI Act Bubble Map</button>
  </nav>

  <section id="global" class="panel active">
    <div class="section-title">
      <h2>Global AI Regulation Comparison</h2>
      <span>EU vs United States vs Argentina</span>
    </div>
    <div class="frame-card">
      <iframe id="globalFrame" title="Global AI Regulation Comparison" src="global-comparison.html" style="height:1250px;"></iframe>
    </div>
  </section>

  <section id="eu" class="panel">
    <div class="section-title">
      <h2>EU AI Act SME Bubble Map</h2>
      <span>Click bubbles to explore obligations, penalties, and SME supports</span>
    </div>
    <div class="frame-card">
      <iframe id="euFrame" title="EU AI Act Bubble Map" src="eu-bubble-map.html" style="height:900px;"></iframe>
    </div>
  </section>
</div>

<script>
const Dashboard = {
  showPanel(panelId, buttonEl) {
    // Hide all panels
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    // Show selected panel
    document.getElementById(panelId).classList.add('active');
    // Update button states
    document.querySelectorAll('.nav button').forEach(b => b.classList.remove('active'));
    buttonEl.classList.add('active');
  }
};
</script>
</body>
</html>
